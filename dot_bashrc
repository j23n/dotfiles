# ~/.bashrc — managed by chezmoi, do not edit directly
# Machine-local overrides go in ~/.bashrc.local

# Non-interactive shells do nothing
case $- in
  *i*) ;;
    *) return ;;
esac

# Load shell modules in order
for _m in env aliases functions prompt; do
  _f="$HOME/.config/shell/${_m}.sh"
  [[ -f "$_f" ]] && source "$_f"
done
unset _m _f

# Machine-local overrides (not committed to git)
[[ -f "$HOME/.bashrc.local" ]] && source "$HOME/.bashrc.local"
